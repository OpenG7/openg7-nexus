{
  "openapi": "3.0.0",
  "info": {
    "title": "OpenG7 API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:1337"
    }
  ],
  "paths": {
    "/api/sectors": {
      "get": {
        "summary": "List sectors",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/provinces": {
      "get": {
        "summary": "List provinces",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/companies": {
      "get": {
        "summary": "List companies",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/exchanges": {
      "get": {
        "summary": "List exchanges",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/homepage": {
      "get": {
        "summary": "Get homepage",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/statistics": {
      "get": {
        "summary": "Fetch statistics summaries",
        "parameters": [
          {
            "name": "scope",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["interprovincial", "international", "all"]
            }
          },
          {
            "name": "intrant",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["all", "energy", "agriculture", "manufacturing", "services"]
            }
          },
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "province",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatisticsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/billing/plans": {
      "get": {
        "summary": "List billing plans",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/BillingPlan"
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "count": {
                          "type": "integer"
                        }
                      },
                      "required": ["count"]
                    }
                  },
                  "required": ["data"]
                }
              }
            }
          }
        }
      }
    },
    "/api/feed": {
      "get": {
        "summary": "List feed items",
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["NEWEST", "URGENCY", "VOLUME", "CREDIBILITY"]
            }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["OFFER", "REQUEST", "ALERT", "TENDER", "CAPACITY", "INDICATOR"]
            }
          },
          {
            "name": "mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["EXPORT", "IMPORT", "BOTH"]
            }
          },
          {
            "name": "sector",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromProvince",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toProvince",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "formKey",
            "in": "query",
            "description": "Exact publication template key stored with feed metadata.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Free-text search across title, summary, source label and publication metadata search text.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedCollectionResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Publish a feed item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedItemResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/hydrocarbon-signals": {
      "get": {
        "summary": "List hydrocarbon publication projections",
        "parameters": [
          {
            "name": "publicationType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["surplus", "slowdown"]
            }
          },
          {
            "name": "storagePressureLevel",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"]
            }
          },
          {
            "name": "originProvinceId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "targetProvinceId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HydrocarbonSignalCollectionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/hydrocarbon-signals/{id}": {
      "get": {
        "summary": "Fetch a hydrocarbon signal projection",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HydrocarbonSignalResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/import-flows": {
      "get": {
        "summary": "Fetch importation flows",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["month", "quarter", "year"]
            }
          },
          {
            "name": "periodValue",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "originScope",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["global", "g7", "usmca", "european_union", "indo_pacific", "custom"]
            }
          },
          {
            "name": "originCodes",
            "in": "query",
            "schema": {
              "oneOf": [
                { "type": "string" },
                { "type": "array", "items": { "type": "string" } }
              ]
            }
          },
          {
            "name": "hsSections",
            "in": "query",
            "schema": {
              "oneOf": [
                { "type": "string" },
                { "type": "array", "items": { "type": "string" } }
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportFlowsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/import-commodities": {
      "get": {
        "summary": "Fetch importation commodities",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportCommodityCollections"
                }
              }
            }
          }
        }
      }
    },
    "/api/import-risk-flags": {
      "get": {
        "summary": "Fetch importation risk flags",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ImportRiskFlag"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/import-suppliers": {
      "get": {
        "summary": "Fetch importation suppliers",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportSuppliersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/import-knowledge": {
      "get": {
        "summary": "Fetch importation knowledge",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["fr", "en"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportKnowledgeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/import-annotations": {
      "get": {
        "summary": "Fetch importation annotations",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportAnnotationsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/import-watchlists": {
      "get": {
        "summary": "Fetch importation watchlists",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportWatchlistsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create importation watchlist",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportWatchlistCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportWatchlist"
                }
              }
            }
          }
        }
      }
    },
    "/api/import-watchlists/{id}": {
      "put": {
        "summary": "Update importation watchlist",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportWatchlistUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportWatchlist"
                }
              }
            }
          }
        }
      }
    },
    "/api/import-reports/schedule": {
      "post": {
        "summary": "Schedule importation report",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportReportScheduleRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportReportScheduleResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Province": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        },
        "required": ["id", "name"]
      },
      "Sector": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        },
        "required": ["id", "name"]
      },
      "CompanyCapacity": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "number", "nullable": true },
          "unit": { "type": "string", "nullable": true }
        },
        "required": ["label"]
      },
      "Company": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "website": { "type": "string", "nullable": true },
          "status": {
            "type": "string",
            "enum": ["pending", "approved", "suspended"]
          },
          "logoUrl": { "type": "string", "nullable": true },
          "secondaryLogoUrl": { "type": "string", "nullable": true },
          "capacities": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CompanyCapacity" }
          },
          "sector": { "$ref": "#/components/schemas/Sector", "nullable": true },
          "province": { "$ref": "#/components/schemas/Province", "nullable": true }
        },
        "required": ["id", "name", "status"]
      },
      "Exchange": {
        "type": "object",
        "properties": {
          "slug": { "type": "string" },
          "title": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "sourceProvince": { "type": "integer" },
          "targetProvince": { "type": "integer" }
        },
        "required": ["slug", "title", "value", "unit", "sourceProvince", "targetProvince"]
      },
      "FeedPublicationFormMetadata": {
        "type": "object",
        "properties": {
          "formKey": { "type": "string" },
          "schemaVersion": { "type": "integer" }
        },
        "required": ["formKey", "schemaVersion"]
      },
      "FeedPublicationMetadata": {
        "type": "object",
        "properties": {
          "publicationForm": {
            "$ref": "#/components/schemas/FeedPublicationFormMetadata"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          }
        }
      },
      "FeedQuantity": {
        "type": "object",
        "properties": {
          "value": { "type": "number" },
          "unit": {
            "type": "string",
            "enum": ["MW", "MWh", "bbl", "bbl_d", "ton", "kg", "hours", "cad", "usd"]
          }
        },
        "required": ["value", "unit"]
      },
      "HydrocarbonSignal": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "feedItemId": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "companyName": { "type": "string" },
          "publicationType": {
            "type": "string",
            "enum": ["surplus", "slowdown"]
          },
          "productType": {
            "type": "string",
            "enum": ["crudeOil", "bitumen", "syntheticCrude", "diesel", "other"]
          },
          "businessReason": {
            "type": "string",
            "enum": ["surplusStock", "demandSlowdown", "transportDisruption", "buyerOutage", "priceWindow"]
          },
          "volumeBarrels": { "type": "number" },
          "quantityUnit": {
            "type": "string",
            "enum": ["bbl", "bbl_d"]
          },
          "minimumLotBarrels": { "type": "number", "nullable": true },
          "availableFrom": { "type": "string", "format": "date", "nullable": true },
          "availableUntil": { "type": "string", "format": "date", "nullable": true },
          "estimatedDelayDays": { "type": "integer", "nullable": true },
          "originProvinceId": { "type": "string", "nullable": true },
          "targetProvinceId": { "type": "string", "nullable": true },
          "originSite": { "type": "string" },
          "qualityGrade": {
            "type": "string",
            "enum": ["wcs", "wtiLinked", "syntheticBlend", "other"]
          },
          "logisticsMode": { "type": "array", "items": { "type": "string" } },
          "targetScope": { "type": "array", "items": { "type": "string" } },
          "storagePressureLevel": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "priceReference": { "type": "string", "nullable": true },
          "responseDeadline": { "type": "string", "format": "date", "nullable": true },
          "contactChannel": { "type": "string" },
          "notes": { "type": "string", "nullable": true },
          "tags": { "type": "array", "items": { "type": "string" } },
          "sourceKind": {
            "type": "string",
            "enum": ["GOV", "COMPANY", "PARTNER", "USER"]
          },
          "sourceLabel": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["active", "expired", "closed"]
          }
        },
        "required": [
          "id",
          "feedItemId",
          "title",
          "summary",
          "companyName",
          "publicationType",
          "productType",
          "businessReason",
          "volumeBarrels",
          "quantityUnit",
          "originSite",
          "qualityGrade",
          "logisticsMode",
          "targetScope",
          "storagePressureLevel",
          "contactChannel",
          "tags",
          "sourceKind",
          "sourceLabel",
          "status"
        ]
      },
      "HydrocarbonSignalResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/HydrocarbonSignal" }
        },
        "required": ["data"]
      },
      "HydrocarbonSignalCollectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HydrocarbonSignal" }
          },
          "meta": {
            "type": "object",
            "properties": {
              "count": { "type": "integer" },
              "limit": { "type": "integer" }
            },
            "required": ["count", "limit"]
          }
        },
        "required": ["data", "meta"]
      },
      "FeedSource": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["GOV", "COMPANY", "PARTNER", "USER"]
          },
          "label": { "type": "string" },
          "url": { "type": "string", "nullable": true }
        },
        "required": ["kind", "label"]
      },
      "FeedItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time", "nullable": true },
          "type": {
            "type": "string",
            "enum": ["OFFER", "REQUEST", "ALERT", "TENDER", "CAPACITY", "INDICATOR"]
          },
          "sectorId": { "type": "string", "nullable": true },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "fromProvinceId": { "type": "string", "nullable": true },
          "toProvinceId": { "type": "string", "nullable": true },
          "mode": {
            "type": "string",
            "enum": ["EXPORT", "IMPORT", "BOTH"]
          },
          "quantity": { "$ref": "#/components/schemas/FeedQuantity", "nullable": true },
          "tags": { "type": "array", "items": { "type": "string" } },
          "metadata": { "$ref": "#/components/schemas/FeedPublicationMetadata", "nullable": true },
          "source": { "$ref": "#/components/schemas/FeedSource" }
        },
        "required": ["id", "createdAt", "type", "title", "summary", "mode", "source"]
      },
      "FeedItemResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/FeedItem" }
        },
        "required": ["data"]
      },
      "FeedCollectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/FeedItem" }
          },
          "cursor": { "type": "string", "nullable": true }
        },
        "required": ["data"]
      },
      "FeedCreateRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["OFFER", "REQUEST", "ALERT", "TENDER", "CAPACITY", "INDICATOR"]
          },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "sectorId": { "type": "string", "nullable": true },
          "fromProvinceId": { "type": "string", "nullable": true },
          "toProvinceId": { "type": "string", "nullable": true },
          "mode": {
            "type": "string",
            "enum": ["EXPORT", "IMPORT", "BOTH"]
          },
          "quantity": { "$ref": "#/components/schemas/FeedQuantity", "nullable": true },
          "tags": { "type": "array", "items": { "type": "string" } },
          "originType": {
            "type": "string",
            "enum": ["alert", "opportunity", "indicator"],
            "nullable": true
          },
          "originId": { "type": "string", "nullable": true },
          "connectionMatchId": { "type": "integer", "nullable": true },
          "metadata": { "$ref": "#/components/schemas/FeedPublicationMetadata", "nullable": true }
        },
        "required": ["type", "title", "summary", "mode"]
      },
      "BillingPlanPrice": {
        "type": "object",
        "properties": {
          "amount": { "type": "integer" },
          "currency": { "type": "string" },
          "interval": {
            "type": "string",
            "enum": ["month", "year"]
          }
        },
        "required": ["amount", "currency", "interval"]
      },
      "BillingPlanCapabilities": {
        "type": "object",
        "properties": {
          "premiumVisibility": { "type": "boolean" },
          "priorityAnalytics": { "type": "boolean" }
        },
        "required": ["premiumVisibility", "priorityAnalytics"]
      },
      "BillingPlan": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tier": {
            "type": "string",
            "enum": ["free", "premium"]
          },
          "provider": {
            "type": "string",
            "enum": ["internal", "stripe"]
          },
          "price": { "$ref": "#/components/schemas/BillingPlanPrice" },
          "features": { "type": "array", "items": { "type": "string" } },
          "capabilities": { "$ref": "#/components/schemas/BillingPlanCapabilities" },
          "i18nKey": { "type": "string" },
          "highlight": { "type": "boolean" },
          "available": { "type": "boolean" }
        },
